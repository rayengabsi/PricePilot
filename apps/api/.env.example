# Database
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/pricepilot"

# Auth
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Server
PORT=3000
# Comma-separated origins; default allows frontend on port 3001
CORS_ORIGIN="http://localhost:3001,http://localhost:3000"

# Price check scheduler
ENABLE_PRICE_CHECK=true
PRICE_CHECK_INTERVAL="0 * * * *"

# Email (Ethereal.email used automatically in dev when SMTP_* not set)
EMAIL_ENABLED=true
EMAIL_FROM=noreply@pricepilot.com

# Optional: Production SMTP (if set, overrides Ethereal)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=user
# SMTP_PASS=password

# Best Buy API (optional)
# BESTBUY_API_KEY=your_api_key
# BESTBUY_BASE_URL=https://api.bestbuy.com/v1
